   "source": [
    "# Identification of upward/downward patterns\n",
    "\n",
    "weekly_revenue = df.groupby(pd.Grouper(key='transaction_datetime', freq='W'))['revenue'].sum()\n",
    "\n",
    "# Calculate change\n",
    "trend = weekly_revenue.diff()\n",
    "\n",
    "trend_df = pd.DataFrame({\n",
    "    \"Weekly Revenue\": weekly_revenue,\n",
    "    \"Change\": trend\n",
    "})\n",
    "\n",
    "print(trend_df.head())\n",
    "\n",
    "# Plot trend graph\n",
    "plt.figure(figsize=(10,5))\n",
    "plt.plot(trend_df.index, trend_df[\"Weekly Revenue\"], marker='o')\n",
    "\n",
    "plt.title(\"Weekly Revenue Trend (Upward / Downward Patterns)\")\n",
    "plt.xlabel(\"Week\")\n",
    "plt.ylabel(\"Revenue\")\n",
    "plt.xticks(rotation=45)\n",
    "\n",
    "plt.show()"
   ]
